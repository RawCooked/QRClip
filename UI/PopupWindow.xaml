<Window x:Class="QRClip.UI.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Focusable="True">

    <Window.Resources>
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEE"/>
                                <Setter Property="Foreground" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F8FAFB"
            CornerRadius="14"
            BorderBrush="#D0D4D8"
            BorderThickness="1"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="6"/>
        </Border.Effect>

        <StackPanel MinWidth="280">
            <!-- Header -->
            <Grid Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x25A6;" FontSize="16" Foreground="#555" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="QRClip" FontSize="14" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource CloseBtn}"
                        Content="&#x2715;"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        ToolTip="Fermer (Échap)"/>
            </Grid>

            <!-- QR Code -->
            <Border Background="White" CornerRadius="8" Padding="8"
                    BorderBrush="#E8EAED" BorderThickness="1">
                <Image x:Name="QrImage"
                       Width="280" Height="280"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>

            <!-- URL label -->
            <TextBlock x:Name="UrlText"
                       MaxWidth="280"
                       FontSize="11"
                       Foreground="#666"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>

            <!-- Hint -->
            <TextBlock Text="Échap · clic hors fenêtre pour fermer"
                       FontSize="10"
                       Foreground="#BBBBBB"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>
    </Border>
</Window>
