<Window x:Class="QRClip.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QRClip — Paramètres"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#F5F6F7">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryBtn">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Logo header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <!-- QR icon drawn in pure XAML -->
            <Viewbox Width="40" Height="40" Margin="0,0,12,0">
                <Canvas Width="32" Height="32">
                    <!-- Outer border -->
                    <Rectangle Canvas.Left="0" Canvas.Top="0" Width="32" Height="32" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="2" Canvas.Top="2" Width="28" Height="28" Fill="White"/>
                    <!-- Top-left finder -->
                    <Rectangle Canvas.Left="4" Canvas.Top="4" Width="10" Height="10" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="6" Canvas.Top="6" Width="6" Height="6" Fill="White"/>
                    <Rectangle Canvas.Left="7" Canvas.Top="7" Width="4" Height="4" Fill="#1A1A2E"/>
                    <!-- Top-right finder -->
                    <Rectangle Canvas.Left="18" Canvas.Top="4" Width="10" Height="10" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="20" Canvas.Top="6" Width="6" Height="6" Fill="White"/>
                    <Rectangle Canvas.Left="21" Canvas.Top="7" Width="4" Height="4" Fill="#1A1A2E"/>
                    <!-- Bottom-left finder -->
                    <Rectangle Canvas.Left="4" Canvas.Top="18" Width="10" Height="10" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="6" Canvas.Top="20" Width="6" Height="6" Fill="White"/>
                    <Rectangle Canvas.Left="7" Canvas.Top="21" Width="4" Height="4" Fill="#1A1A2E"/>
                    <!-- Data modules -->
                    <Rectangle Canvas.Left="16" Canvas.Top="16" Width="4" Height="4" Fill="#0078D4"/>
                    <Rectangle Canvas.Left="22" Canvas.Top="20" Width="3" Height="3" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="20" Canvas.Top="24" Width="3" Height="3" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="16" Canvas.Top="22" Width="3" Height="3" Fill="#1A1A2E"/>
                    <Rectangle Canvas.Left="24" Canvas.Top="16" Width="4" Height="3" Fill="#1A1A2E"/>
                </Canvas>
            </Viewbox>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="QRClip" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
                <TextBlock Text="Paramètres" FontSize="12" Foreground="#888" Margin="0,1,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Hotkey section -->
        <Border Background="White" CornerRadius="8" BorderBrush="#DDD"
                BorderThickness="1" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Raccourci clavier" FontSize="13" FontWeight="SemiBold"
                           Foreground="#333" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Modificateurs  "
                               FontSize="12" Foreground="#444" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <CheckBox x:Name="ChkCtrl"  Content="Ctrl"  IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkShift" Content="Shift" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkAlt"   Content="Alt"                    VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkWin"   Content="Win"                    VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Touche  "
                               FontSize="12" Foreground="#444" VerticalAlignment="Center"/>
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1"
                                CornerRadius="4" Background="White" Padding="8,6">
                            <TextBlock x:Name="HotkeyDisplay" FontSize="13" FontWeight="Medium"
                                       Foreground="#333" VerticalAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="2" x:Name="BtnCapture"
                                Content="Capturer" Style="{StaticResource SecondaryBtn}"
                                Click="BtnCapture_Click"/>
                    </Grid>
                </Grid>

                <TextBlock x:Name="HotkeyStatus" FontSize="11" Foreground="#888"
                           Text="Cliquez sur Capturer puis appuyez sur la combinaison souhaitée."/>
            </StackPanel>
        </Border>

        <!-- Démarrage section -->
        <Border Background="White" CornerRadius="8" BorderBrush="#DDD"
                BorderThickness="1" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Démarrage" FontSize="13" FontWeight="SemiBold"
                           Foreground="#333" Margin="0,0,0,10"/>
                <CheckBox x:Name="ChkAutoStart"
                          Content="Lancer QRClip automatiquement au démarrage de Windows"
                          FontSize="12" Foreground="#444"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler"     Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Enregistrer" Style="{StaticResource PrimaryBtn}"   Click="BtnSave_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
